{
  "installCommand": "npm install && npm install --prefix api",
  "buildCommand": "npm install && npm install --prefix api",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10,
      "includeFiles": "node_modules/@neondatabase/**"
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" }
  ]
}
