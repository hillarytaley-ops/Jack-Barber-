{
  "installCommand": "npm install && npm install --prefix api",
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10,
      "includeFiles": "node_modules/@neondatabase/**"
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" }
  ]
}
